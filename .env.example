# Environment Variables Example File
# Rename this file to .env.local for local development

# NEXT_PUBLIC_API_URL=https://api.example.com

# ─── Resend Email Service ────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Email address where lead notifications will be sent
LEAD_RECEIVER_EMAIL=YOUR_COMPANY_EMAIL@gmail.com

# ─── Google Sheets Backup (Optional) ─────────────────
# Deploy a Google Apps Script Web App and paste the URL below
# If not set, leads will still be emailed — sheet backup is optional
# GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
